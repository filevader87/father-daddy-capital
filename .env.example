# Runtime configuration.
# Copy values into your shell, process manager, or secret store.
# Do not commit real credentials.

CONFIG_PATH=config/trading.yaml
TRADING_MODE=paper

# Alpaca paper/live execution credentials, only required when live execution is enabled.
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Optional market/news providers.
FINNHUB_API_KEY=
NEWSAPI_API_KEY=
CRYPTOPANIC_API_KEY=
COINMARKETCAP_API_KEY=

# Optional notifications.
ENABLE_NOTIFICATIONS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# API service settings.
JWT_SECRET=
